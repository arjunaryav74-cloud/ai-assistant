{
  "appId": "com.nova.mac",
  "productName": "Nova",
  "protocols": [{ "name": "Nova", "schemes": ["nova"] }],
  "asarUnpack": ["**/*.node"],
  "files": ["out/**", "build/**", "package.json"],
  "extraResources": [{ "from": "electron/wakeword/models", "to": "wakeword-models" }],
  "mac": {
    "category": "public.app-category.productivity",
    "target": ["dmg"],
    "hardenedRuntime": true,
    "gatekeeperAssess": false,
    "entitlements": "build/entitlements.mac.plist",
    "entitlementsInherit": "build/entitlements.mac.plist",
    "extendInfo": {
      "NSMicrophoneUsageDescription": "Nova listens for the wake word and records your voice commands.",
      "NSAppleEventsUsageDescription": "Nova automates apps with AppleScript when you ask it to.",
      "NSSpeechRecognitionUsageDescription": "Nova transcribes your voice commands."
    },
    "notarize": true
  },
  "win": {
    "target": ["nsis"]
  },
  "nsis": {
    "oneClick": true,
    "deleteAppDataOnUninstall": false
  }
}
