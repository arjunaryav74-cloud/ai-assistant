{
  "name": "nova-mac",
  "version": "0.1.0",
  "description": "Nova — native macOS helper",
  "main": "out/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "dist": "npm run build && electron-builder --mac",
    "wake:models": "node scripts/download-wake-models.mjs"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "node-addon-api": "^8.2.0",
    "node-gyp": "^10.2.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@supabase/supabase-js": "^2.108.2",
    "@types/ws": "^8.18.1",
    "bindings": "^1.5.0",
    "dotenv": "^16.6.1",
    "framer-motion": "^11.11.0",
    "googleapis": "^173.0.0",
    "onnxruntime-node": "^1.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ws": "^8.21.0"
  }
}
